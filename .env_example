# MongoDB root credentials. The db container creates this user on first init;
# the updater, server, and legacy Python app authenticate with it against the
# admin database. Secrets — replace the placeholders below.
OBSERVER_MONGO_USER=default
OBSERVER_MONGO_PASS=default

# MongoDB database name and the article/feed collection names the app uses.
OBSERVER_MONGO_DB=observer
OBSERVER_MONGO_ARTICLES=articles
OBSERVER_MONGO_FEEDS=feeds

# YandexGPT (300.ya.ru) OAuth token used to summarize articles. Required by the
# updater; the read-only server does not need it. Replace the placeholder.
OBSERVER_AUTH_TOKEN=default

# Port the Streamlit frontend (the Python "app" service) listens on.
OBSERVER_SL_PORT=8501

# How often the updater refreshes every feed, in seconds. It is also each
# cycle's deadline, so a stuck cycle never runs longer than one interval.
OBSERVER_FEED_UPDATE_TIMEOUT=600

# Lifetime of the read server's in-memory cache of the feeds response, in seconds.
OBSERVER_FEED_CACHE_TTL=60

# Test-only (go/internal/repository integration tests); unused by the running app.
# Point the suite at a dedicated test MongoDB — never production: it creates and
# drops databases on the target server.
# E.g. mongodb://root:test-password@localhost:27017.
# Leave empty to use testcontainers with Docker.
OBSERVER_TEST_MONGO_URI=

# Fail (instead of skip) the integration tests when no MongoDB is available.
# Any non-empty value enables this (including 0 and false); empty disables it.
# CI also triggers it automatically via the CI variable.
OBSERVER_TEST_REQUIRE_MONGO=
