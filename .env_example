# MongoDB root credentials. The db container creates this user on first init;
# the updater and server authenticate with it against the admin database.
# Secrets — replace the placeholders below.
OBSERVER_MONGO_USER=default
OBSERVER_MONGO_PASS=default

# MongoDB host the updater and server connect to. "db" is the compose service;
# point it elsewhere (host:port) to use an external MongoDB.
OBSERVER_MONGO_HOST=db

# MongoDB database name and the article/feed collection names the backend uses.
OBSERVER_MONGO_DB=observer
OBSERVER_MONGO_ARTICLES=articles
OBSERVER_MONGO_FEEDS=feeds

# YandexGPT (300.ya.ru) OAuth token used to summarize articles. Required by the
# updater; the read-only server does not need it. Replace the placeholder.
OBSERVER_AUTH_TOKEN=default

# How often the updater starts a new refresh cycle, in seconds.
OBSERVER_FEED_UPDATE_INTERVAL=600

# Hard deadline for one refresh cycle, in seconds. A cycle that exceeds it is
# cancelled (its unfinished work resumes next cycle) so it can't run forever.
OBSERVER_FEED_UPDATE_TIMEOUT=600

# Lifetime of the feeds caches, in seconds — used by both the read server's
# in-memory response cache and the frontend's data cache.
OBSERVER_FEED_CACHE_TTL=60

# Host port docker compose publishes the read server on.
OBSERVER_SERVER_PORT=8080

# Port the Streamlit frontend listens on.
OBSERVER_SL_PORT=8501

# Base URL the frontend fetches feeds from — no trailing slash. "server" is the
# compose service.
OBSERVER_BACKEND_URL=http://server:8080

# Test-only (backend/internal/repository integration tests); unused by the running services.
# Point the suite at a dedicated test MongoDB — never production: it creates and
# drops databases on the target server.
# E.g. mongodb://root:test-password@localhost:27017.
# Leave empty to use testcontainers with Docker.
OBSERVER_TEST_MONGO_URI=

# Fail (instead of skip) the integration tests when no MongoDB is available.
# Any non-empty value enables this (including 0 and false); empty disables it.
# CI also triggers it automatically via the CI variable.
OBSERVER_TEST_REQUIRE_MONGO=
